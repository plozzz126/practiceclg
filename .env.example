# Direct local run values.
APP_ENV=development
PORT=8080
DATABASE_URL=postgres://devlink:devlink@localhost:5432/devlink?sslmode=disable
REDIS_URL=redis://localhost:6379/0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
SKILLS_CACHE_TTL=1h
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Optional Docker-only overrides for compose.
# DOCKER_DATABASE_URL=postgres://devlink:devlink@postgres:5432/devlink?sslmode=disable
# DOCKER_REDIS_URL=redis://redis:6379/0
# DOCKER_NEXT_PUBLIC_API_URL=http://localhost:8080/api
